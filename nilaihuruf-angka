<!doctype html>
<html>
  <head>
    <title>Konversi Nilai Huruf</title>
  </head>
  <body>
    <h2>Program Konversi Nilai</h2>

    <input type="number" id="nilai" placeholder="Masukkan nilai" />
    <button onclick="cekNilai()">Proses</button>

    <p id="hasil"></p>

    <script>
      function cekNilai() {
        let nilai = Number(document.getElementById("nilai").value);
        let hasil = "";

        if (nilai >= 0 && nilai <= 20) {
          hasil = "Nilai Huruf: E";
        } else if (nilai >= 21 && nilai <= 39) {
          hasil = "Nilai Huruf: D";
        } else if (nilai >= 40 && nilai <= 64) {
          hasil = "Nilai Huruf: C";
        } else if (nilai >= 65 && nilai <= 79) {
          hasil = "Nilai Huruf: B";
        } else if (nilai >= 80 && nilai <= 100) {
          hasil = "Nilai Huruf: A";
        } else {
          hasil = "Nilai tidak valid";
        }

        document.getElementById("hasil").innerHTML = hasil;
      }
    </script>
  </body>
</html>
